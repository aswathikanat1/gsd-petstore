{
    "name": "gsd-petstore-api",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "nodemon --watch src --exec ts-node src/index.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/index.js",
        "lint": "eslint . --ext .ts",
        "openapi:lint": "redocly lint petstore.yaml",
        "docs:generate": "redocly lint petstore.yaml && redocly build-docs petstore.yaml --output docs/api-reference.html",
        "test": "vitest run --globals",
        "test:contract": "vitest run --globals"
    },
    "dependencies": {
        "express": "^5.1.0",
        "openapi-backend": "^5.12.0",
        "redoc-express": "^2.1.0",
        "yamljs": "^0.3.0"
    },
    "devDependencies": {
        "@redocly/cli": "^2.30.6",
        "@types/express": "^5.0.3",
        "@types/node": "^22.15.18",
        "@types/yamljs": "^0.2.34",
        "@typescript-eslint/eslint-plugin": "^8.44.1",
        "@typescript-eslint/parser": "^8.44.1",
        "eslint": "^8.57.1",
        "nodemon": "^3.1.10",
        "ts-node": "^10.9.2",
        "typescript": "^5.6.3",
        "vitest": "^4.1.6"
    }
}
